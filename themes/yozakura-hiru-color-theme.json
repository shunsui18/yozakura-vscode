	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#7868a0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#287848"
			}
		},
		{
			"name": "String escape / special chars",
			"scope": [
				"constant.character.escape",
				"string.regexp"
			],
			"settings": {
				"foreground": "#2878a8"
			}
		},
		{
			"name": "Numbers",
			"scope": [
				"constant.numeric",
				"constant.numeric.integer",
				"constant.numeric.float"
			],
			"settings": {
				"foreground": "#887018"
			}
		},
		{
			"name": "Boolean / Null / Undefined",
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined",
				"constant.language"
			],
			"settings": {
				"foreground": "#985818"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.control.flow",
				"keyword.control.import",
				"keyword.control.export",
				"keyword.other"
			],
			"settings": {
				"foreground": "#6030a0"
			}
		},
		{
			"name": "Storage type/modifier",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#6030a0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#4e3e6e"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.accessor",
				"meta.brace"
			],
			"settings": {
				"foreground": "#7868a0"
			}
		},
		{
			"name": "Functions — declaration",
			"scope": [
				"entity.name.function",
				"meta.function entity.name.function"
			],
			"settings": {
				"foreground": "#2858b8"
			}
		},
		{
			"name": "Functions — calls",
			"scope": [
				"support.function",
				"meta.function-call entity.name.function",
				"variable.function"
			],
			"settings": {
				"foreground": "#286890"
			}
		},
		{
			"name": "Classes / Types",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.other.inherited-class",
				"support.class"
			],
			"settings": {
				"foreground": "#a03868"
			}
		},
		{
			"name": "Interfaces",
			"scope": [
				"entity.name.type.interface"
			],
			"settings": {
				"foreground": "#2878a8"
			}
		},
		{
			"name": "Type parameters / Generics",
			"scope": [
				"entity.name.type.parameter"
			],
			"settings": {
				"foreground": "#2878a8",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Namespaces / Modules",
			"scope": [
				"entity.name.namespace",
				"entity.name.module",
				"support.module"
			],
			"settings": {
				"foreground": "#2a1848"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"variable.other",
				"variable.other.readwrite"
			],
			"settings": {
				"foreground": "#2a1848"
			}
		},
		{
			"name": "Parameters",
			"scope": [
				"variable.parameter"
			],
			"settings": {
				"foreground": "#4e3e6e",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Properties / Object keys",
			"scope": [
				"variable.other.property",
				"variable.other.object.property",
				"support.type.property-name",
				"meta.object-literal.key"
			],
			"settings": {
				"foreground": "#4840b0"
			}
		},
		{
			"name": "Constants — user defined",
			"scope": [
				"variable.other.constant",
				"constant.other"
			],
			"settings": {
				"foreground": "#a86018"
			}
		},
		{
			"name": "Enum members",
			"scope": [
				"variable.other.enummember"
			],
			"settings": {
				"foreground": "#985818"
			}
		},
		{
			"name": "HTML/JSX — Tags",
			"scope": [
				"entity.name.tag",
				"meta.tag.sgml"
			],
			"settings": {
				"foreground": "#a02868"
			}
		},
		{
			"name": "HTML/JSX — Attributes",
			"scope": [
				"entity.other.attribute-name",
				"meta.tag entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#a86018",
				"fontStyle": "italic"
			}
		},
		{
			"name": "CSS — Selectors",
			"scope": [
				"entity.other.attribute-name.class.css",
				"entity.other.attribute-name.id.css",
				"entity.name.tag.css"
			],
			"settings": {
				"foreground": "#a02868"
			}
		},
		{
			"name": "CSS — Properties",
			"scope": [
				"support.type.property-name.css"
