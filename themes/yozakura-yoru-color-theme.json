	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#9098c0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#7aa898"
			}
		},
		{
			"name": "String escape / special chars",
			"scope": [
				"constant.character.escape",
				"string.regexp"
			],
			"settings": {
				"foreground": "#7ab0c8"
			}
		},
		{
			"name": "Numbers",
			"scope": [
				"constant.numeric",
				"constant.numeric.integer",
				"constant.numeric.float"
			],
			"settings": {
				"foreground": "#e8d870"
			}
		},
		{
			"name": "Boolean / Null / Undefined",
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined",
				"constant.language"
			],
			"settings": {
				"foreground": "#f2d4b8"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.control.flow",
				"keyword.control.import",
				"keyword.control.export",
				"keyword.other"
			],
			"settings": {
				"foreground": "#b898d0"
			}
		},
		{
			"name": "Storage type/modifier",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#b898d0",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#b0bcd8"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation.separator",
				"punctuation.terminator",
				"punctuation.accessor",
				"meta.brace"
			],
			"settings": {
				"foreground": "#9098c0"
			}
		},
		{
			"name": "Functions — declaration",
			"scope": [
				"entity.name.function",
				"meta.function entity.name.function"
			],
			"settings": {
				"foreground": "#6080b8"
			}
		},
		{
			"name": "Functions — calls",
			"scope": [
				"support.function",
				"meta.function-call entity.name.function",
				"variable.function"
			],
			"settings": {
				"foreground": "#7ab0c8"
			}
		},
		{
			"name": "Classes / Types",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.other.inherited-class",
				"support.class"
